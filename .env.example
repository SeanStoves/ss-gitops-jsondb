# GitHub App credentials. Register an App, grant it contents:write + metadata:read
# on the content repo, install it, and grab these from the App settings page.

# numeric App ID from the App's General settings
GH_APP_ID=

# numeric installation ID (the .../installations/<id> in the install URL, or via the API)
GH_APP_INSTALLATION_ID=

# the App's private key (.pem download) base64-encoded. The Next adapter decodes it;
# if you pass the PEM straight to installationToken(), skip the base64 step.
GH_APP_PRIVATE_KEY=

# the webhook secret you set when configuring the App's webhook
GH_WEBHOOK_SECRET=

# absolute path to the content repo checkout on disk (cwd for every git call)
CONTENT_DIR=

# remote base whose requests get the auth header, e.g. https://github.com/
# for GitHub Enterprise point it at your GHE host
CONTENT_REMOTE=https://github.com/

# optional: GitHub Enterprise API base. defaults to https://api.github.com
# GH_API_BASE_URL=https://ghe.example.com/api/v3
